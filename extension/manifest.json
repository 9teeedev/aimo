{
  "manifest_version": 3,
  "name": "aimo — AI Usage Monitor",
  "version": "0.3.0",
  "description": "Unified usage/limit viewer for ZAI, Claude, Codex, Ollama Cloud, DeepSeek, and MiniMax.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://ollama.com/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://api.z.ai/*",
    "https://api.deepseek.com/*",
    "https://platform.minimax.io/*",
    "https://www.minimax.io/*",
    "http://localhost:3030/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Usage Monitor"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["http://localhost:3030/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://z.ai/*", "https://chat.z.ai/*"],
      "js": ["content-zai.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://platform.minimax.io/*"],
      "js": ["content-minimax.js"],
      "run_at": "document_idle"
    }
  ]
}
